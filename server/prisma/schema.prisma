generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

enum LookingFor {
  RELATIONSHIP
  CASUAL_DATES
  PARTY_PARTNER
  FRIENDS
  HANGOUTS
  WATCH_MOVIE
  EXPLORING_CITY_AND_CAFE
  TIME_SPENDING
  FINDING_OUT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model User {
  id            String   @id @db.Uuid
  email         String?

  authName      String?   // Google / Apple name (hidden, metadata)
  displayName   String?   // User-entered name (shown in app)
  username      String?   @unique // Unique username
  surname       String?   // private, optional

  dob           DateTime? @db.Date
  gender        Gender?
  interestedIn  Gender[]
  height        String?
  city          String?
  lookingFor    LookingFor[]

  onboardingCompleted Boolean @default(false)
  onboardingStep      Int     @default(0)

  matchesAsUser1 Match[] @relation("UserMatch1")
  matchesAsUser2 Match[] @relation("UserMatch2")

  likesGiven      Like[]   @relation("UserLikesGiven")
  likesReceived   Like[]   @relation("UserLikesReceived")
  rejectsGiven    Reject[] @relation("UserRejectsGiven")
  rejectsReceived Reject[] @relation("UserRejectsReceived")

  chatParticipants ChatParticipant[]
  messagesSent     Message[] @relation("UserMessages")

  last_active DateTime @default(now())
  createdAt DateTime @default(now())

  profile          Profile?
  photos           Photo[]
  filterPreference FilterPreference?

  @@map("users")
}


// Stores per-user discovery filter preferences (filter-specific only)
// interestedIn is on User model, availableNext8Days is on Profile model
model FilterPreference {
  userId        String @id @db.Uuid

  minAge        Int    @default(18)
  maxAge        Int    @default(80)
  maxDistanceKm Int    @default(50)
  filterByAvailability Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("filter_preferences")
}


model Profile {
  userId             String   @id @db.Uuid
  prompts            Json?
  bio                String?
  viewerQuestion     String?
  viewerPollOptions  String[]
  viewerPollAnswer   Int?
  availableNext8Days Boolean[]

  location Unsupported("geography(Point,4326)")?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Photo {
  id        String  @id @default(uuid())
  userId    String  @db.Uuid
  imageUrl  String
  position  Int
  isPrimary Boolean @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, position])
  @@map("photos")
}

model Match {
  id        String   @id @default(uuid())
  user1Id   String   @db.Uuid
  user2Id   String   @db.Uuid
  createdAt DateTime @default(now())

  user1 User @relation("UserMatch1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2 User @relation("UserMatch2", fields: [user2Id], references: [id], onDelete: Cascade)

  chat Chat?

  @@unique([user1Id, user2Id])
  @@map("matches")
}

model Chat {
  id        String   @id @default(uuid())
  matchId   String?  @unique
  createdAt DateTime @default(now())

  match        Match?           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  participants ChatParticipant[]
  messages     Message[]

  @@map("chats")
}

model ChatParticipant {
  id     String @id @default(uuid())
  chatId String
  userId String @db.Uuid

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@map("chat_participants")
}

model Message {
  id       String   @id @default(uuid())
  chatId   String
  senderId String   @db.Uuid

  text      String
  createdAt DateTime  @default(now())
  seenAt    DateTime?

  chat   Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender User @relation("UserMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@map("messages")
}

model Like {
  id       String   @id @default(uuid())
  liker_id String   @db.Uuid
  liked_id String   @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  liker User @relation("UserLikesGiven", fields: [liker_id], references: [id], onDelete: Cascade)
  liked User @relation("UserLikesReceived", fields: [liked_id], references: [id], onDelete: Cascade)

  @@unique([liker_id, liked_id])
  @@map("likes")
}

model Reject {
  id          String   @id @default(uuid())
  rejecter_id String   @db.Uuid
  rejected_id String   @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  rejecter User @relation("UserRejectsGiven", fields: [rejecter_id], references: [id], onDelete: Cascade)
  rejected User @relation("UserRejectsReceived", fields: [rejected_id], references: [id], onDelete: Cascade)

  @@unique([rejecter_id, rejected_id])
  @@map("rejects")
}
